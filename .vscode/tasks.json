{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ng-serve",
      "type": "shell",
      "command": "npm run start -- --configuration development",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": {
        "pattern": { "regexp": "^ERROR in (.*)$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Generating browser application bundles",
          "endsPattern": "Compiled successfully"
        }
      }
    },
    {
      "label": "ng-serve-mock",
      "type": "shell",
      "command": "npm run start -- --configuration development",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "NG_APP_MOCK_API": "true" }
      },
      "group": "none",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": {
        "pattern": { "regexp": "^ERROR in (.*)$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Generating browser application bundles",
          "endsPattern": "Compiled successfully"
        }
      }
    },
    {
      "label": "ng-serve-proxy",
      "type": "shell",
      "command": "npm run start -- --configuration development --proxy-config proxy.conf.json",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": {
        "pattern": { "regexp": "^ERROR in (.*)$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Generating browser application bundles",
          "endsPattern": "Compiled successfully"
        }
      }
    },
    {
      "label": "ng-build",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "ng-test",
      "type": "shell",
      "command": "npm run test -- --no-watch --browsers=ChromeHeadless",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "ng-lint",
      "type": "shell",
      "command": "npm run lint",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "playwright-test",
      "type": "shell",
      "command": "npx playwright test",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "format",
      "type": "shell",
      "command": "npm run format",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "problemMatcher": []
    }
  ]
}
